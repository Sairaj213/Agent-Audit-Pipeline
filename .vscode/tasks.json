{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Frontend",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "group": "project-runner",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "isBackground": true
        },
        {
            "label": "Run Backend",
            "type": "shell",
            "command": "python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "group": "project-runner",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "isBackground": true
        },
        {
            "label": "Start Full Project",
            "dependsOn": [
                "Run Frontend",
                "Run Backend"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
